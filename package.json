{
  "name": "fix-my-halo",
  "type": "module",
  "license": "MIT",
  "private": true,
  "version": "0.0.0",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "pnpm run build:wasm && vite build",
    "build:wasm": "wasm-pack build core --target web --out-dir ../src/pkg --no-pack",
    "vercel-build": "bash scripts/vercel-build.sh",
    "build:cli": "tsx scripts/build-cli.ts",
    "preview": "pnpm run build && vite preview",
    "test:cli": "cargo run --manifest-path core/Cargo.toml --features cli",
    "test:cli-unit": "cargo test --manifest-path core/Cargo.toml",
    "lint": "pnpm run \"/lint:./\"",
    "lint:tsc": "tsc -b",
    "lint:eslint": "eslint . --max-warnings 0",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "4.2.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vite-plugin-wasm": "^3.6.0",
    "wasm-pack": "^0.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "wasm-pack"
    ],
    "ignoredBuiltDependencies": [
      "@tailwindcss/oxide"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
